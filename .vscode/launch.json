{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (web)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/artifacts/bin/{{ProjectEgenesisName}}.App/debug/{{ProjectEgenesisName}}.App.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/{{ProjectEgenesisName}}.App",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": "Run {{ProjectEgenesisName}}.exe",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-release-exe",
            "program": "${workspaceFolder}/artifacts/release/{{ProjectEgenesisName}}.exe",
            "args": [],
            "cwd": "${workspaceFolder}/artifacts/release",
            "stopAtEntry": false
        }
    ]
}